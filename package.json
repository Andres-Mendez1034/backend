{
  "name": "brand-connect-backend",
  "version": "1.0.0",
  "description": "Backend de Brand Connect",
  "homepage": "https://github.com/Andres-Mendez1034/backend#readme",
  "bugs": {
    "url": "https://github.com/Andres-Mendez1034/backend/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Andres-Mendez1034/backend.git"
  },
  "license": "ISC",
  "author": "",
  "type": "module",
  "main": "src/bootstrap.js",
  "scripts": {
    "dev": "nodemon src/bootstrap.js",
    "start": "node src/bootstrap.js",
    "test": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand",
    "test:watch": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --watch",
    "test:coverage": "cross-env NODE_ENV=test node --experimental-vm-modules node_modules/jest/bin/jest.js --coverage"
  },
  "dependencies": {
    "axios": "^1.16.0",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.6",
    "dotenv": "^16.3.1",
    "express": "^4.22.1",
    "multer": "^2.1.1",
    "pg": "^8.20.0",
    "qrcode": "^1.5.4",
    "react-markdown": "^10.1.0",
    "speakeasy": "^2.0.0",
    "stripe": "^22.1.1",
    "swagger-jsdoc": "^6.2.8",
    "swagger-ui-express": "^5.0.1",
    "validator": "^13.15.35",
    "yaml": "^2.8.1"
  },
  "devDependencies": {
    "cross-env": "^10.1.0",
    "jest": "^30.4.2",
    "nodemon": "^3.1.0",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "verbose": true,
    "transform": {},
    "testMatch": [
      "**/*.test.js"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/test-QA/setup/setup.js"
    ],
    "reporters": [
      "default",
      "<rootDir>/test-QA/setup/test-reporter.js"
    ]
  }
}
